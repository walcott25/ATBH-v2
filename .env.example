[TEMPLATE]
# NVIDIA_API_KEY: Required for NVIDIA NIM API calls.
# Get your free API key at https://build.nvidia.com/
NVIDIA_API_KEY="nvapi-YOUR_NVIDIA_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Clerk Webhook Signing Secret
# Get this from Clerk Dashboard > Webhooks > your endpoint > "Signing Secret"
CLERK_WEBHOOK_SIGNING_SECRET="whsec_your_signing_secret_here"

# Google Analytics 4 (configured via GTM)
# GA4 tags are set up in the Google Tag Manager dashboard:
# https://tagmanager.google.com/ (container: GTM-KXCQK5TX)
# No env vars needed — the analytics service pushes events to the dataLayer,
# and GTM handles sending them to GA4.
#
# If you switch back to direct gtag (no GTM), uncomment below:
# VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
